# ===== Target =====
CONFIG_TARGET_amlogic=y
CONFIG_TARGET_amlogic_s912=y
CONFIG_TARGET_amlogic_s912_DEVICE_Tanix-TX8-Max=y

# ===== Base =====
CONFIG_PACKAGE_luci=y
CONFIG_PACKAGE_luci-ssl=y
CONFIG_PACKAGE_luci-theme-bootstrap=y
CONFIG_PACKAGE_dnsmasq-full=y
CONFIG_PACKAGE_coreutils=y
CONFIG_PACKAGE_coreutils-nohup=y
CONFIG_PACKAGE_ca-certificates=y

# ===== OpenClash（旁路由核心）=====
CONFIG_PACKAGE_luci-app-openclash=y
CONFIG_PACKAGE_kmod-tun=y
CONFIG_PACKAGE_ipset=y

# ===== Daed（高性能透明代理）=====
CONFIG_PACKAGE_daed=y
CONFIG_PACKAGE_luci-app-daed=y

# ===== MosDNS（DNS 加速）=====
CONFIG_PACKAGE_mosdns=y
CONFIG_PACKAGE_luci-app-mosdns=y

# ===== Turbo ACC（极致加速核心）=====
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_SHORTCUT_FE=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_FLOW_OFFLOAD=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_BBR_CCA=y
CONFIG_PACKAGE_luci-app-turboacc_INCLUDE_FULLCONE_NAT=y

# ===== 加速内核模块（全部拉满）=====
CONFIG_PACKAGE_kmod-fast-classifier=y
CONFIG_PACKAGE_kmod-shortcut-fe=y
CONFIG_PACKAGE_kmod-shortcut-fe-cm=y
CONFIG_PACKAGE_kmod-ipt-offload=y
CONFIG_PACKAGE_kmod-nf-flow=y
CONFIG_PACKAGE_fullconenat=y
CONFIG_PACKAGE_kmod-tcp-bbr=y
CONFIG_PACKAGE_kmod-tcp-bbr2=y
CONFIG_PACKAGE_irqbalance=y
CONFIG_PACKAGE_kmod-inet-diag=y

# ===== 旁路由必备（TProxy / NAT Helper）=====
CONFIG_PACKAGE_iptables-mod-tproxy=y
CONFIG_PACKAGE_ip-full=y
CONFIG_PACKAGE_kmod-nf-nathelper=y
CONFIG_PACKAGE_kmod-nf-nathelper-extra=y

# ===== 常用工具 =====
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget=y
CONFIG_PACKAGE_unzip=y
CONFIG_PACKAGE_tar=y
