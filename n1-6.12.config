# ==============================================================================
# 【第一部分 N1硬件 6.12内核固定配置 禁止删除/注释】
# ==============================================================================
CONFIG_TARGET_amlogic=y
CONFIG_TARGET_amlogic_s905d=y
CONFIG_AMLOGIC_BOARD_NAME="phicomm-n1"
# 锁定Flippy 6.12内核
CONFIG_AMLOGIC_KERNEL_VERSION="6.12"
# 晶晨宝盒：EMMC刷机、内核切换、硬件管理工具
CONFIG_PACKAGE_luci-app-amlogic=y
CONFIG_PACKAGE_luci-i18n-amlogic-zh-cn=y
# N1无线WiFi驱动
CONFIG_PACKAGE_flippy-wifi=y
# 文件系统EXT4，固件基础分区1G
CONFIG_TARGET_ROOTFS_EXT4FS=y
CONFIG_TARGET_ROOTFS_PARTSIZE=1024

# ==============================================================================
# 【第二部分 Docker容器内核底层依赖，必须全部开启】
# ==============================================================================
CONFIG_CGROUPS=y
CONFIG_CGROUP_CPUACCT=y
CONFIG_CGROUP_MEMORY=y
CONFIG_CGROUP_PIDS=y
CONFIG_NAMESPACES=y
CONFIG_OVERLAY_FS=y
CONFIG_VETH=y
CONFIG_BRIDGE=y
CONFIG_POSIX_MQUEUE=y
CONFIG_SECCOMP=y
CONFIG_CAPABILITIES=y
CONFIG_CGROUP_DEVICE=y
CONFIG_CGROUP_FREEZER=y
CONFIG_CGROUP_SCHED=y
CONFIG_USER_NS=y
CONFIG_MEMCG_SWAP=y
CONFIG_MEMCG_KMEM=y

# ==============================================================================
# 【第三部分 Docker全套容器服务】
# ==============================================================================
# Docker主程序核心
CONFIG_PACKAGE_docker=y
CONFIG_PACKAGE_dockerd=y
# Docker网页可视化管理面板
CONFIG_PACKAGE_luci-app-dockerman=y
CONFIG_PACKAGE_luci-i18n-dockerman-zh-cn=y
# Docker Compose 多容器编排
CONFIG_PACKAGE_docker-compose=y

# ==============================================================================
# 【第四部分 DNS解析+全局广告拦截 SmartDNS + AdGuardHome】
# ==============================================================================
# SmartDNS 多上游并发解析、IP优选、防DNS污染
CONFIG_PACKAGE_smartdns=y
CONFIG_PACKAGE_luci-app-smartdns=y
CONFIG_PACKAGE_luci-i18n-smartdns-zh-cn=y

# AdGuardHome 全局DNS广告拦截、恶意域名屏蔽
CONFIG_PACKAGE_adguardhome=y
CONFIG_PACKAGE_luci-app-adguardhome=y
CONFIG_PACKAGE_luci-i18n-adguardhome-zh-cn=y

# ==============================================================================
# 【第五部分 代理插件 Passwall + ClashOO】
# ==============================================================================
# Passwall 分流代理核心
CONFIG_PACKAGE_passwall-core=y
CONFIG_PACKAGE_luci-app-passwall=y
CONFIG_PACKAGE_luci-i18n-passwall-zh-cn=y

# ClashOO Clash内核网页管理面板
CONFIG_PACKAGE_luci-app-clashoo=y
CONFIG_PACKAGE_luci-i18n-clashoo-zh-cn=y

# ==============================================================================
# 【第六部分 全套VPN服务端：IPSec / PPTP / OpenVPN】
# ==============================================================================
# IPSec VPN服务端
CONFIG_PACKAGE_luci-app-ipsec-vpnserver=y
CONFIG_PACKAGE_luci-i18n-ipsec-vpnserver-zh-cn=y
# PPTP VPN服务端
CONFIG_PACKAGE_luci-app-pptp-server=y
CONFIG_PACKAGE_luci-i18n-pptp-server-zh-cn=y
# OpenVPN服务端
CONFIG_PACKAGE_luci-app-openvpn-server=y
CONFIG_PACKAGE_luci-i18n-openvpn-server-zh-cn=y

# ==============================================================================
# 【第七部分 TurboACC 网络网速加速、TCP拥塞优化】
# ==============================================================================
CONFIG_PACKAGE_luci-app-turboacc=y
CONFIG_PACKAGE_luci-i18n-turboacc-zh-cn=y

# ==============================================================================
# 【第八部分 DDNS 动态域名，外网访问内网服务】
# ==============================================================================
CONFIG_PACKAGE_luci-app-ddns=y
CONFIG_PACKAGE_luci-i18n-ddns-zh-cn=y

# ==============================================================================
# 【第九部分 vlmcsd KMS激活服务器】
# ==============================================================================
CONFIG_PACKAGE_vlmcsd=y
CONFIG_PACKAGE_luci-app-vlmcsd=y
CONFIG_PACKAGE_luci-i18n-vlmcsd-zh-cn=y

# ==============================================================================
# 【第十部分 DiskMan磁盘管理 硬盘挂载/分区/扩容/格式化】
# ==============================================================================
CONFIG_PACKAGE_luci-app-diskman=y
CONFIG_PACKAGE_luci-i18n-diskman-zh-cn=y

# ==============================================================================
# 【第十一部分 Nlbwmon 内网带宽流量监控】
# ==============================================================================
CONFIG_PACKAGE_luci-app-nlbwmon=y
CONFIG_PACKAGE_luci-i18n-nlbwmon-zh-cn=y

# ==============================================================================
# 【第十二部分 TTYD 网页SSH终端】
# ==============================================================================
CONFIG_PACKAGE_luci-app-ttyd=y
CONFIG_PACKAGE_luci-i18n-ttyd-zh-cn=y

# ==============================================================================
# 【第十三部分 Design美化主题 + 设置面板 + 中文汉化】
# ==============================================================================
CONFIG_PACKAGE_luci-theme-design=y
CONFIG_PACKAGE_luci-app-design-config=y
CONFIG_PACKAGE_luci-i18n-design-config-zh-cn=y

# ==============================================================================
# 【第十四部分 AutoReboot 定时自动重启路由】
# ==============================================================================
CONFIG_PACKAGE_luci-app-autoreboot=y
CONFIG_PACKAGE_luci-i18n-autoreboot-zh-cn=y

# ==============================================================================
# 【第十五部分 FileTransfer 网页文件上传下载工具】
# ==============================================================================
CONFIG_PACKAGE_luci-app-filetransfer=y
CONFIG_PACKAGE_luci-i18n-filetransfer-zh-cn=y

# ==============================================================================
# 【第十六部分 单臂路由必备：流卸载/UPnP/端口转发/IPv6/配置备份】
# ==============================================================================
# FlowOffload 流量硬件卸载，大幅降低N1单臂转发CPU占用
CONFIG_PACKAGE_luci-app-flowoffload=y

# UPnP 自动端口映射，游戏/PT下载
CONFIG_PACKAGE_luci-app-upnp=y
CONFIG_PACKAGE_luci-i18n-upnp-zh-cn=y

# 高级自定义端口转发
CONFIG_PACKAGE_luci-app-portforward=y
CONFIG_PACKAGE_luci-i18n-portforward-zh-cn=y

# IPv6完整支持套件，PPPoE IPv6拨号分发
CONFIG_PACKAGE_ipv6helper=y

# 固件配置一键备份恢复
CONFIG_PACKAGE_luci-app-backup=y
CONFIG_PACKAGE_luci-i18n-backup-zh-cn=y

# ==============================================================================
# 【第十七部分 系统基础依赖工具】
# ==============================================================================
CONFIG_PACKAGE_htop=y
CONFIG_PACKAGE_openssh-sftp-server=y
CONFIG_PACKAGE_curl=y
CONFIG_PACKAGE_wget-full=y

